# Required for IE extraction (OpenAI Batch API) and KGC enrichment
OPENAI_API_KEY=sk-...

# Required for IE corpus/search stages (NCBI E-Utilities)
NCBI_API_KEY=...
NCBI_EMAIL=user@example.com

# Optional: PostgreSQL connection (used by DB load step)
# These default to the values in infra/docker-compose.yml.
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=foodatlas
# DB_USER=foodatlas
# DB_PASSWORD=foodatlas
